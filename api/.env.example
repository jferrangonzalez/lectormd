# ─────────────────────────────────────────────
# lectormd — configuración del backend
# Copiá este archivo como .env y completá los valores.
# ─────────────────────────────────────────────

# Ruta absoluta al directorio donde viven los proyectos (carpetas con .md)
# Ejemplo Linux:  /home/usuario/docs
# Ejemplo macOS:  /Users/usuario/mis-lecturas
# Ejemplo Windows (si usás XAMPP/Laragon): C:/laragon/www/lectormd/data/docs
DOCS_PATH=/ruta/a/tus/documentos

# Ruta absoluta al archivo de base de datos SQLite (se crea solo si no existe)
DB_PATH=/ruta/a/tus/documentos/lecturas.db

# Credenciales de acceso a la interfaz web
AUTH_USER=usuario
AUTH_PASS=contraseña-segura
