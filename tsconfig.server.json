{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "./dist-server",
    "rootDir": "./server",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["server"]
}
