# Configuracion de lectormd. Copia este archivo como .env y completa los valores.
# NO commitear el .env real - contiene secretos.

# Ruta absoluta donde se guardan los .md (un subdir por proyecto).
DOCS_PATH=/ruta/absoluta/a/tus/documentos

# Ruta absoluta al archivo SQLite. Se autocrea si no existe.
DB_PATH=/ruta/absoluta/a/lectormd.db

# Credenciales Basic Auth para el endpoint /api/*.
AUTH_USER=admin
AUTH_PASS=cambiame

# Puerto del servidor Node. Default 8080 si no se especifica.
PORT=8080
